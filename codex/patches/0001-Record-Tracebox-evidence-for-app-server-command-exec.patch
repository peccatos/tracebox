diff --git a/codex-rs/app-server/src/tracebox_evidence.rs b/codex-rs/app-server/src/tracebox_evidence.rs
new file mode 100644
index 0000000..b80edab
--- /dev/null
+++ b/codex-rs/app-server/src/tracebox_evidence.rs
@@ -0,0 +1,276 @@
+use std::env;
+use std::fs;
+use std::io::Write;
+use std::path::PathBuf;
+
+use anyhow::Context;
+use chrono::Utc;
+use serde::Serialize;
+use sha2::Digest;
+use sha2::Sha256;
+use uuid::Uuid;
+
+/// Environment variable that enables the local Tracebox proof recorder.
+///
+/// This is intentionally opt-in. Codex tests and normal app-server execution
+/// must not write evidence bundles unless the developer explicitly asks for it.
+const TRACEBOX_ENABLED_ENV: &str = "TRACEBOX_ENABLED";
+
+/// Environment variable that selects where trace directories are written.
+///
+/// The value is treated as a direct trace root. Unlike the standalone tracebox
+/// CLI, this proof writer does not create a nested `.traces` directory by
+/// default. That keeps the integration test easy to inspect:
+///
+/// ```text
+/// TRACEBOX_ROOT=/tmp/codex-tracebox-proof
+/// /tmp/codex-tracebox-proof/trc_...
+/// ```
+const TRACEBOX_ROOT_ENV: &str = "TRACEBOX_ROOT";
+
+/// Minimal command execution record passed from `command_exec`.
+///
+/// This type deliberately contains only data that is already available at the
+/// app-server boundary after execution. The recorder must not own process
+/// execution, otherwise it would change command/exec semantics and could break
+/// stdout/stderr delivery to clients.
+#[derive(Debug, Clone)]
+pub(crate) struct TraceboxCommandEvidence {
+    /// Command argv as Codex executed it.
+    pub(crate) command: Vec<String>,
+
+    /// Working directory used for the command.
+    pub(crate) cwd: PathBuf,
+
+    /// Process exit code observed by Codex.
+    pub(crate) exit_code: i32,
+
+    /// Captured stdout returned to the command/exec caller.
+    pub(crate) stdout: String,
+
+    /// Captured stderr returned to the command/exec caller.
+    pub(crate) stderr: String,
+
+    /// Human-readable execution path marker.
+    ///
+    /// Examples:
+    /// - `command_exec.windows_sandbox`
+    /// - `command_exec.local_spawn`
+    ///
+    /// The value is metadata only; it avoids pretending that every Codex
+    /// command path is identical internally.
+    pub(crate) source: &'static str,
+}
+
+/// Write a Tracebox-compatible evidence bundle if explicitly enabled.
+///
+/// Failure to write evidence is reported to the caller but must not be treated
+/// as command execution failure. The command already ran; breaking command/exec
+/// because a diagnostic sidecar failed would be the wrong coupling.
+pub(crate) fn maybe_record_command_evidence(
+    evidence: TraceboxCommandEvidence,
+) -> anyhow::Result<Option<PathBuf>> {
+    if !tracebox_enabled() {
+        return Ok(None);
+    }
+
+    let trace_root = trace_root_from_env()?;
+    fs::create_dir_all(&trace_root).with_context(|| {
+        format!(
+            "failed to create Tracebox evidence root {}",
+            trace_root.display()
+        )
+    })?;
+
+    let trace_id = format!("trc_{}", Uuid::now_v7());
+    let trace_dir = trace_root.join(&trace_id);
+
+    // Use create_dir instead of create_dir_all for the final trace directory.
+    // A UUID collision is effectively impossible, but create_dir makes an
+    // accidental overwrite structurally impossible.
+    fs::create_dir(&trace_dir)
+        .with_context(|| format!("failed to create Tracebox trace {}", trace_dir.display()))?;
+
+    let stdout_sha256 = sha256_hex(evidence.stdout.as_bytes());
+    let stderr_sha256 = sha256_hex(evidence.stderr.as_bytes());
+
+    write_file_atomic(trace_dir.join("stdout.log"), evidence.stdout.as_bytes())?;
+    write_file_atomic(trace_dir.join("stderr.log"), evidence.stderr.as_bytes())?;
+
+    let now = Utc::now().to_rfc3339();
+
+    let manifest = TraceboxManifest {
+        manifest_version: 1,
+        trace_id: trace_id.clone(),
+        tool_kind: "codex-command-exec",
+        source: evidence.source,
+        command: evidence.command,
+        cwd: evidence.cwd.display().to_string(),
+        started_at: now.clone(),
+        finished_at: now,
+        duration_ms: 0,
+        exit_code: evidence.exit_code,
+        artifacts: TraceboxArtifacts {
+            stdout: "stdout.log",
+            stderr: "stderr.log",
+            pty: None,
+        },
+        integrity: TraceboxIntegrity {
+            stdout_sha256,
+            stderr_sha256,
+            pty_sha256: None,
+        },
+    };
+
+    let manifest_json =
+        serde_json::to_vec_pretty(&manifest).context("failed to serialize Tracebox manifest")?;
+
+    let manifest_sha256 = sha256_hex(&manifest_json);
+
+    write_file_atomic(trace_dir.join("manifest.json"), &manifest_json)?;
+    write_file_atomic(
+        trace_dir.join("manifest.sha256"),
+        format!("{manifest_sha256}  manifest.json\n").as_bytes(),
+    )?;
+
+    Ok(Some(trace_dir))
+}
+
+fn tracebox_enabled() -> bool {
+    match env::var(TRACEBOX_ENABLED_ENV) {
+        Ok(value) => {
+            let value = value.trim().to_ascii_lowercase();
+            matches!(value.as_str(), "1" | "true" | "yes" | "on")
+        }
+        Err(_) => false,
+    }
+}
+
+fn trace_root_from_env() -> anyhow::Result<PathBuf> {
+    let value = env::var(TRACEBOX_ROOT_ENV).with_context(|| {
+        format!("{TRACEBOX_ROOT_ENV} must be set when Tracebox evidence is enabled")
+    })?;
+
+    let trimmed = value.trim();
+
+    anyhow::ensure!(
+        !trimmed.is_empty(),
+        "{TRACEBOX_ROOT_ENV} must not be empty when Tracebox evidence is enabled"
+    );
+
+    Ok(PathBuf::from(trimmed))
+}
+
+fn sha256_hex(bytes: &[u8]) -> String {
+    let digest = Sha256::digest(bytes);
+    format!("{digest:x}")
+}
+
+fn write_file_atomic(path: PathBuf, bytes: &[u8]) -> anyhow::Result<()> {
+    let parent = path
+        .parent()
+        .with_context(|| format!("path has no parent: {}", path.display()))?;
+
+    fs::create_dir_all(parent)
+        .with_context(|| format!("failed to create parent directory {}", parent.display()))?;
+
+    let file_name = path
+        .file_name()
+        .and_then(|name| name.to_str())
+        .with_context(|| format!("path has invalid file name: {}", path.display()))?;
+
+    let tmp_path = parent.join(format!(".{file_name}.tmp-{}", Uuid::now_v7()));
+
+    {
+        let mut file = fs::File::create(&tmp_path)
+            .with_context(|| format!("failed to create temp file {}", tmp_path.display()))?;
+
+        file.write_all(bytes)
+            .with_context(|| format!("failed to write temp file {}", tmp_path.display()))?;
+
+        file.sync_all()
+            .with_context(|| format!("failed to fsync temp file {}", tmp_path.display()))?;
+    }
+
+    fs::rename(&tmp_path, &path).with_context(|| {
+        format!(
+            "failed to rename {} to {}",
+            tmp_path.display(),
+            path.display()
+        )
+    })?;
+
+    Ok(())
+}
+
+#[derive(Debug, Serialize)]
+struct TraceboxManifest {
+    manifest_version: u32,
+    trace_id: String,
+    tool_kind: &'static str,
+    source: &'static str,
+    command: Vec<String>,
+    cwd: String,
+    started_at: String,
+    finished_at: String,
+    duration_ms: u128,
+    exit_code: i32,
+    artifacts: TraceboxArtifacts,
+    integrity: TraceboxIntegrity,
+}
+
+#[derive(Debug, Serialize)]
+struct TraceboxArtifacts {
+    stdout: &'static str,
+    stderr: &'static str,
+    pty: Option<&'static str>,
+}
+
+#[derive(Debug, Serialize)]
+struct TraceboxIntegrity {
+    stdout_sha256: String,
+    stderr_sha256: String,
+    pty_sha256: Option<String>,
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+
+    #[test]
+    fn tracebox_enabled_accepts_common_truthy_values() {
+        assert!(matches_truthy("1"));
+        assert!(matches_truthy("true"));
+        assert!(matches_truthy("yes"));
+        assert!(matches_truthy("on"));
+
+        assert!(!matches_truthy("0"));
+        assert!(!matches_truthy("false"));
+        assert!(!matches_truthy(""));
+    }
+
+    fn matches_truthy(value: &str) -> bool {
+        let value = value.trim().to_ascii_lowercase();
+        matches!(value.as_str(), "1" | "true" | "yes" | "on")
+    }
+
+    #[test]
+    fn sha256_hex_returns_lowercase_digest() {
+        assert_eq!(
+            sha256_hex(b"hello"),
+            "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824"
+        );
+    }
+
+    #[test]
+    fn write_file_atomic_creates_file_contents() -> anyhow::Result<()> {
+        let temp = tempfile::TempDir::new()?;
+        let path = temp.path().join("nested").join("file.txt");
+
+        write_file_atomic(path.clone(), b"ok")?;
+
+        assert_eq!(fs::read_to_string(path)?, "ok");
+
+        Ok(())
+    }
+}
